# Copy to .env on production host. Do not commit real secrets.

NODE_ENV=production

# Docker build only — npm mirror when registry.npmjs.org is unreachable (optional)
# NPM_REGISTRY=https://registry.npmmirror.com

DATABASE_URL="postgresql://kangba_app:CHANGE_ME@postgres:5432/kangba?schema=public"
REDIS_URL="redis://redis:6379"

# openssl rand -hex 32
JWT_SECRET="REPLACE_WITH_64_CHAR_HEX"
ADMIN_API_KEY="REPLACE_WITH_STRONG_RANDOM_KEY"

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_NONCE_TTL_MINUTES=5
EMAIL_CODE_TTL_MINUTES=10

MOCK_SMTP=false
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT=587
SMTP_FROM="noreply@yourdomain.com"
# SMTP_USER=
# SMTP_PASS=

PORT=4000
HOST=0.0.0.0
API_INTERNAL_URL=http://api:4000

CORS_ORIGINS="https://yourdomain.com,https://admin.yourdomain.com"

NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_API_URL="https://yourdomain.com"
NEXT_PUBLIC_WC_PROJECT_ID="your-walletconnect-project-id"
NEXT_PUBLIC_ADMIN_API_KEY="same-as-ADMIN_API_KEY-for-admin-build"
NEXT_PUBLIC_ENABLE_TWITTER_LOGIN=true
NEXT_PUBLIC_ENABLE_EMAIL_LOGIN=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
API_PUBLIC_URL=https://yourdomain.com
WEB_PUBLIC_URL=https://yourdomain.com
OAUTH_DEV_MOCK=false

ADMIN_SEED_EMAIL="admin@yourdomain.com"
ADMIN_SEED_PASSWORD="REPLACE_STRONG_PASSWORD_MIN_12"
ADMIN_EDITOR_EMAIL="editor@yourdomain.com"
ADMIN_EDITOR_PASSWORD="REPLACE_STRONG_PASSWORD_MIN_12"

HTTP_PORT=80
HTTPS_PORT=443
SSL_REDIRECT=1

POSTGRES_USER=postgres
POSTGRES_PASSWORD="REPLACE_DB_PASSWORD"
POSTGRES_DB=kangba
