DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kangba?schema=public"

REDIS_URL="redis://localhost:6379"

JWT_SECRET="kangba-secret"

NEXT_PUBLIC_WC_PROJECT_ID="demo"

# Optional overrides (defaults work for local Docker + host dev)
PORT=4000
HOST=0.0.0.0
API_INTERNAL_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_NONCE_TTL_MINUTES=5
EMAIL_CODE_TTL_MINUTES=10
MOCK_SMTP=true

ADMIN_API_KEY="dev-admin-key-change-in-production"
NEXT_PUBLIC_ADMIN_API_KEY="dev-admin-key-change-in-production"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Admin 预览上传图片时可指向站点或 API 静态目录
ADMIN_SEED_EMAIL="admin@kangba.local"
ADMIN_SEED_PASSWORD="kangba-admin-change-me"
ADMIN_EDITOR_EMAIL="editor@kangba.local"
ADMIN_EDITOR_PASSWORD="kangba-editor-change-me"
ADMIN_VIEWER_EMAIL="viewer@kangba.local"
ADMIN_VIEWER_PASSWORD="kangba-viewer-change-me"

# Production nginx (docker-compose.prod.yml)
HTTP_PORT=80
HTTPS_PORT=443
SSL_REDIRECT=0

CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
