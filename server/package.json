{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "prisma:generate": "dotenv -e ../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate deploy",
    "prisma:migrate:dev": "dotenv -e ../.env -- prisma migrate dev",
    "prisma:push": "dotenv -e ../.env -- prisma db push",
    "db:seed": "dotenv -e ../.env -- tsx prisma/seed.ts",
    "lint": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^6.3.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "pino": "^9.6.0",
    "viem": "^2.22.17",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.10",
    "@types/nodemailer": "^6.4.17",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
